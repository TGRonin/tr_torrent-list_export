# 后端配置目录（容器内路径）
TR_CONFIG_DIR=/app/config

# Transmission 连接配置（保存在 /app/config/config.json，可由 API 写入）
TRANSMISSION_HOST=192.168.3.119
TRANSMISSION_PORT=9091
TRANSMISSION_USERNAME=admin
TRANSMISSION_PASSWORD=admin

# 前端构建期 API 基地址（默认空字符串=同域）
# 若需要构建时指定外部 API（例如 http://localhost:8000），可在 build 时传入 VITE_API_BASE
VITE_API_BASE=
